# The production build (npm run build → tsc + vite) needs the build toolchain
# (typescript, vite, plugins) which lives in devDependencies. Railway/Nixpacks
# sets NODE_ENV=production, which makes `npm ci` omit devDependencies by
# default — so `tsc`/`vite` end up "not found" and the build fails with exit 127.
# Forcing `include=dev` overrides that omission so the build tools are present.
# (Runtime doesn't reinstall, so this only affects the build/install step.)
include=dev
