{
  "name": "volleyball-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "node --watch --env-file=.env server/index.js",
    "dev:admin": "node --watch --env-file=.env.admin server/admin-server.js",
    "dev:admin:web": "vite --config vite.admin.config.ts",
    "build": "tsc --noEmit && vite build && vite build --config vite.admin.config.ts",
    "start": "node server/start.js",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@sentry/node": "^10.57.0",
    "@sentry/react": "^10.57.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "sharp": "^0.35.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9"
  }
}
