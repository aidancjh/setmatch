# Copy this file to ".env" and fill in real values for local development.
# In production (Railway), set these as environment variables in the dashboard.

# PostgreSQL connection string.
# Local example (after installing Postgres locally):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/setmatch

# Set to "true" for managed/cloud databases that require TLS (Railway, Neon, etc.).
# Leave unset (or "false") for a local Postgres.
DATABASE_SSL=false

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=local-dev-secret-not-for-production

# Port the API listens on (the host usually sets this automatically).
PORT=4000

# Sentry error monitoring DSN (optional — errors are still logged to console without it).
# Get this from sentry.io → Settings → Projects → your project → Client Keys (DSN).
# SENTRY_DSN     → backend (server) errors.
# VITE_SENTRY_DSN → frontend (browser) errors. Safe to expose; it can only submit events.
SENTRY_DSN=
VITE_SENTRY_DSN=

# Cloudinary (optional — only needed for avatar and highlight uploads).
# VITE_ prefix exposes these to the browser bundle intentionally (unsigned upload preset).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# Server-side cloud name used to scope which Cloudinary URLs the API accepts
# (avatars, banners, highlights). Set this to the SAME value as
# VITE_CLOUDINARY_CLOUD_NAME so uploads must belong to your account, not just any
# Cloudinary account. Leave unset to accept any res.cloudinary.com URL (legacy).
CLOUDINARY_CLOUD_NAME=

# Public base URL of the app. Used for CORS, OAuth redirect URIs, and links in
# emails. In production set this to your real domain, e.g. https://coterie.com.de
APP_URL=http://localhost:5173

# Comma-separated emails that should be granted the admin role on startup.
ADMIN_EMAILS=

# Resend API key for transactional email (join confirmations, password resets).
# Optional — emails are skipped (with a console warning) when unset.
RESEND_API_KEY=

# Google OAuth (optional — enables "Sign in with Google").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Seed demo users + sample past games/reviews on startup. Defaults to enabled.
# Set to "false" in production to launch with a clean database (no public demo
# logins like 1@demo.test/111111, no fake content).
SEED_DEMO=true
