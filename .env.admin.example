# Marks this as a local dev environment so the admin service boots with the
# placeholder ADMIN_JWT_SECRET below. In production set NODE_ENV=production in
# Railway — the service then refuses to start unless ADMIN_JWT_SECRET and
# ADMIN_PASSWORD_HASH are set to strong, non-placeholder values.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/setmatch
DATABASE_SSL=false
DB_POOL_MAX=5
PORT=4100
APP_URL=http://localhost:5174
ADMIN_JWT_SECRET=replace-with-a-generated-secret
ADMIN_EMAILS=you@example.com
# Admin login: a single shared password, bcrypt-hashed at rest.
# Generate the hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# Never commit the plaintext password anywhere — only the hash goes in this env var.
ADMIN_PASSWORD_HASH=
# Which existing admin user (by email, from ADMIN_EMAILS above) the password logs into.
ADMIN_LOGIN_EMAIL=you@example.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
